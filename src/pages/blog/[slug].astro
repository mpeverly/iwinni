---
import BlogPost from '../../layouts/BlogPost.astro';

const { slug } = Astro.params;

if (!slug) {
	return Astro.redirect('/404');
}

let article = null;
try {
	const env = Astro.locals.runtime.env;
	const DB = env.DB || env.iwinni_blog;
	if (DB) {
		article = await DB.prepare(
			"SELECT * FROM articles WHERE slug = ?"
		).bind(slug).first();
	}
} catch (e) {
	console.error("Failed to query D1 database:", e);
}

if (!article) {
	return Astro.redirect('/404');
}

// Convert D1 database format to BlogPost expected properties
const pubDate = article.date ? new Date(article.date) : new Date();

// Extract image URL from main_story
const imgMatch = article.main_story ? article.main_story.match(/!\[.*?\]\((.*?)\)/) : null;
const heroImage = imgMatch ? imgMatch[1] : '/hero-patagonia.jpg';

// Strip image and split into paragraphs
const textOnly = article.main_story ? article.main_story.replace(/!\[.*?\]\(.*?\)/, '').trim() : '';

// Helper to convert basic markdown links and bold text to HTML
function formatMarkdown(text) {
	if (!text) return '';
	return text
		.replace(/\[(.*?)\]\((.*?)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
		.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
}

const paragraphs = textOnly.split(/\n\s*\n/).filter(Boolean).map(formatMarkdown);
---

<BlogPost
	title={article.title}
	description={article.summary || article.title}
	pubDate={pubDate}
	heroImage={heroImage}
>
	<div class="prose">
		{paragraphs.map((html) => <p set:html={html} />)}
		
		{article.feel_good && (
			<>
				<hr />
				<h3>The Last Chair</h3>
				<p set:html={formatMarkdown(article.feel_good)} />
			</>
		)}

		{article.sources && (
			<div class="sources-box" style="margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-cream-dark); font-size: 0.85rem; color: var(--color-muted);">
				<strong>Sources:</strong> {article.sources}
			</div>
		)}
	</div>
</BlogPost>
