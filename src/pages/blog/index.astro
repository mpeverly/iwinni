---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_DESCRIPTION } from '../../consts';
import FormattedDate from '../../components/FormattedDate.astro';

let articles = [];
try {
	const env = Astro.locals.runtime.env;
	const DB = env.DB || env.iwinni_blog;
	if (DB) {
		const { results } = await DB.prepare(
			"SELECT title, slug, date, category, summary, hero_image FROM articles ORDER BY date DESC"
		).all();
		articles = results || [];
	}
} catch (e) {
	console.error("Failed to query D1 database for stories list:", e);
}

// Inline fallback mapping for styling badges
const categoryBadgeMap: Record<string, string> = {
	'global travel': 'badge-travel',
	'outdoor adventure': 'badge-adventure',
	'high-altitude exploration': 'badge-altitude',
	'high-altitude': 'badge-altitude'
};

function getBadgeClass(cat: string) {
	const normalized = (cat || '').toLowerCase().trim();
	return categoryBadgeMap[normalized] ?? 'badge-adventure';
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Stories" description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="stories-main">

			<div class="stories-hero">
				<span class="section-label">Dispatches</span>
				<h1>Stories</h1>
				<p>Deeply researched briefs from the world's most iconic regions.</p>
			</div>

			{articles.length === 0 ? (
				<div class="empty-state">
					<p>No stories published yet. Stay tuned as we build our trail log.</p>
				</div>
			) : (
				<ul class="post-list" role="list">
					{articles.map((article, i) => {
						const badgeClass = getBadgeClass(article.category);
						const pubDate = article.date ? new Date(article.date) : new Date();
						const heroImage = article.hero_image || '/hero-patagonia.jpg';
						return (
							<li class:list={['post-item', i === 0 ? 'post-item--featured' : '']}>
								<a href={`/blog/${article.slug}/`} class="post-link">
									<div class="post-img-wrap">
										<img
											src={heroImage}
											alt={article.title}
											loading={i === 0 ? 'eager' : 'lazy'}
										/>
									</div>
									<div class="post-content">
										<div class="post-meta">
											<span class={`badge ${badgeClass}`}>{article.category || 'Adventure'}</span>
											<span class="post-date"><FormattedDate date={pubDate} /></span>
										</div>
										<h2 class="post-title">{article.title}</h2>
										<p class="post-desc">{article.summary}</p>
										<span class="post-cta">Read Brief →</span>
									</div>
								</a>
							</li>
						);
					})}
				</ul>
			)}

		</main>
		<Footer />
	</body>
</html>

<style>
	.stories-main {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 3rem 2rem 5rem;
	}

	/* Page header */
	.stories-hero {
		margin-bottom: 3rem;
		padding-bottom: 2rem;
		border-bottom: 1px solid var(--color-cream-dark);
	}
	.section-label {
		display: inline-block;
		font-family: var(--font-display);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-green);
		margin-bottom: 0.6rem;
	}
	.stories-hero h1 {
		margin: 0 0 0.5rem;
		font-size: clamp(2rem, 5vw, 3rem);
	}
	.stories-hero p {
		color: var(--color-muted);
		font-size: 1.05rem;
		margin: 0;
	}

	/* Empty state */
	.empty-state {
		text-align: center;
		padding: 4rem 1.5rem;
		background: var(--color-cream-dark);
		border-radius: 12px;
		color: var(--color-muted);
		font-family: var(--font-body);
	}

	/* Post list */
	.post-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.post-item {
		border-bottom: 1px solid var(--color-cream-dark);
	}
	.post-link {
		display: grid;
		grid-template-columns: 280px 1fr;
		gap: 2rem;
		padding: 2rem 0;
		text-decoration: none;
		color: inherit;
		transition: opacity 0.2s;
	}
	.post-link:hover { opacity: 0.85; }
	.post-link:hover .post-title { color: var(--color-green); }

	/* Featured (first) post */
	.post-item--featured .post-link {
		grid-template-columns: 1fr;
		gap: 1.25rem;
	}
	.post-item--featured .post-img-wrap {
		aspect-ratio: 21/9;
		border-radius: 12px;
	}
	.post-item--featured .post-title {
		font-size: clamp(1.4rem, 3vw, 2rem);
	}

	.post-img-wrap {
		aspect-ratio: 16/9;
		overflow: hidden;
		border-radius: 10px;
		flex-shrink: 0;
		background: var(--color-cream-dark);
	}
	.post-img-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.3s ease;
	}
	.post-link:hover .post-img-wrap img { transform: scale(1.04); }

	.post-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.5rem;
	}
	.post-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.post-date {
		font-family: var(--font-display);
		font-size: 0.78rem;
		color: var(--color-muted);
		font-weight: 500;
	}
	.post-title {
		font-size: 1.3rem;
		margin: 0;
		line-height: 1.25;
		color: var(--color-charcoal);
		transition: color 0.2s;
	}
	.post-desc {
		font-size: 0.9rem;
		color: var(--color-muted);
		margin: 0;
		line-height: 1.55;
	}
	.post-cta {
		font-family: var(--font-display);
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--color-green);
		margin-top: 0.25rem;
	}

	@media (max-width: 720px) {
		.stories-main { padding: 2rem 1.25rem 4rem; }
		.post-link {
			grid-template-columns: 1fr;
			gap: 1rem;
		}
		.post-img-wrap { aspect-ratio: 16/9; }
	}
</style>
