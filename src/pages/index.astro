---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import FormattedDate from '../components/FormattedDate.astro';

let posts = [];
let debugInfo = {
	hasRuntime: false,
	runtimeKeys: [],
	hasEnv: false,
	envKeys: [],
	error: null,
	postsFetched: 0
};

try {
	if (Astro.locals && Astro.locals.runtime) {
		debugInfo.hasRuntime = true;
		debugInfo.runtimeKeys = Object.keys(Astro.locals.runtime);
		if (Astro.locals.runtime.env) {
			debugInfo.hasEnv = true;
			debugInfo.envKeys = Object.keys(Astro.locals.runtime.env);
			
			const env = Astro.locals.runtime.env;
			const DB = env.DB || env.iwinni_blog;
			if (DB) {
				const { results } = await DB.prepare(
					"SELECT title, slug, date, category, summary, hero_image FROM articles ORDER BY date DESC LIMIT 3"
				).all();
				posts = results || [];
				debugInfo.postsFetched = posts.length;
			} else {
				debugInfo.error = "No database binding found (checked env.DB and env.iwinni_blog)";
			}
		} else {
			debugInfo.error = "Astro.locals.runtime.env is missing";
		}
	} else {
		debugInfo.error = "Astro.locals.runtime is missing";
	}
} catch (e: any) {
	debugInfo.error = e.message || String(e);
}

const categories = [
	{
		icon: '🌍',
		title: 'Global Travel',
		description: 'Destination deep-dives, logistics, and insider perspectives from every corner of the globe.',
	},
	{
		icon: '🏔',
		title: 'Outdoor Adventure',
		description: 'Trail reports, gear analysis, backcountry ops, and the communities that push limits.',
	},
	{
		icon: '⛰',
		title: 'High-Altitude Exploration',
		description: 'Expedition briefings, summit stories, and science from the planet\'s most extreme elevations.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- ── Hero ── -->
		<section class="hero">
			<div class="hero-inner">
				<span class="hero-eyebrow">Media &amp; Publishing</span>
				<h1 class="hero-headline">Navigate the Edge<br />of Adventure</h1>
				<p class="hero-sub">
					Deeply researched stories connecting passionate outdoor enthusiasts
					with authentic perspectives from the world's most iconic regions.
				</p>
				<div class="hero-actions">
					<a href="/blog" class="btn btn-primary">Read Stories</a>
					<a href="/about" class="btn btn-ghost">Our Mission</a>
				</div>
			</div>
			<div class="hero-image-wrap">
				<img
					src="/hero-patagonia.jpg"
					alt="Torres del Paine, Patagonia"
					class="hero-img"
					loading="eager"
					decoding="async"
				/>
				<div class="hero-image-overlay"></div>
			</div>
		</section>

		<!-- ── What We Cover ── -->
		<section class="categories">
			<div class="section-inner">
				<div class="section-header">
					<span class="section-label">What We Cover</span>
					<h2>Stories from the frontier</h2>
					<p>From backcountry operational updates to global destination insights and community highlights.</p>
				</div>
				<div class="category-grid">
					{categories.map((cat) => (
						<div class="category-card">
							<span class="category-icon">{cat.icon}</span>
							<h3>{cat.title}</h3>
							<p>{cat.description}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- ── Latest Stories ── -->
		<section class="latest">
			<div class="section-inner">
				<div class="section-header">
					<span class="section-label">Latest</span>
					<h2>Recent Dispatches</h2>
				</div>
				{posts.length === 0 ? (
					<div class="empty-state">
						<p>No stories published yet. Stay tuned as we build our trail log.</p>
					</div>
				) : (
					<ul class="post-grid" role="list">
						{posts.map((post) => {
							const pubDate = post.date ? new Date(post.date) : new Date();
							const heroImage = post.hero_image || '/hero-patagonia.jpg';
							return (
								<li class="post-card">
									<a href={`/blog/${post.slug}/`} class="post-card-link">
										<div class="post-card-img-wrap">
											<img
												src={heroImage}
												alt={post.title}
												loading="lazy"
												class="post-card-img"
											/>
										</div>
										<div class="post-card-body">
											<p class="post-card-date">
												<FormattedDate date={pubDate} />
											</p>
											<h3 class="post-card-title">{post.title}</h3>
											<p class="post-card-desc">{post.summary}</p>
											<span class="post-card-cta">Read Brief →</span>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				)}
				<div class="all-stories-wrap">
					<a href="/blog" class="btn btn-outline">All Stories</a>
				</div>
			</div>
		</section>

		<!-- ── Newsletter Teaser ── -->
		<section class="newsletter">
			<div class="section-inner newsletter-inner">
				<span class="newsletter-icon">📡</span>
				<h2>Stay on the trail</h2>
				<p>Get the freshest expedition briefs, destination guides, and community updates delivered direct.</p>
				<a href="https://www.linkedin.com/company/iwinni" target="_blank" rel="noopener noreferrer" class="btn btn-gold">
					Follow on LinkedIn
				</a>
			</div>
		</section>

		<!-- Debug Console for D1 -->
		<div style="background: #fee2e2; color: #991b1b; padding: 1.5rem; margin: 2rem auto; max-width: var(--max-width); border-radius: 8px; font-family: monospace; font-size: 0.85rem; border: 1px solid #fecaca;">
			<h3 style="margin-top: 0; color: #991b1b;">🔧 D1 Connection Debugger</h3>
			<pre style="background: rgba(255,255,255,0.7); color: #1c1f1a; padding: 1rem; border-radius: 6px; overflow-x: auto; margin-bottom: 0;">{JSON.stringify(debugInfo, null, 2)}</pre>
		</div>

		<Footer />
	</body>
</html>

<style>
	/* ─── Hero ─────────────────────────────────────────── */
	.hero {
		position: relative;
		min-height: 88vh;
		display: flex;
		align-items: center;
		overflow: hidden;
		background: var(--color-charcoal);
	}
	.hero-image-wrap {
		position: absolute;
		inset: 0;
		z-index: 0;
	}
	.hero-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		filter: brightness(0.45) saturate(0.85);
	}
	.hero-image-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			135deg,
			rgba(28,31,26,0.82) 0%,
			rgba(45,90,39,0.35) 60%,
			transparent 100%
		);
	}
	.hero-inner {
		position: relative;
		z-index: 1;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 5rem 2rem 5rem;
		width: 100%;
	}
	.hero-eyebrow {
		display: inline-block;
		font-family: var(--font-display);
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-gold);
		margin-bottom: 1.2rem;
		border: 1px solid rgba(200,151,58,0.4);
		padding: 0.3em 0.9em;
		border-radius: 999px;
		background: rgba(200,151,58,0.08);
	}
	.hero-headline {
		font-family: var(--font-display);
		font-size: clamp(2.8rem, 7vw, 5.5rem);
		font-weight: 900;
		line-height: 1.05;
		color: var(--color-cream);
		letter-spacing: -0.02em;
		margin: 0 0 1.25rem;
		max-width: 700px;
	}
	.hero-sub {
		font-family: var(--font-body);
		font-size: clamp(1rem, 2vw, 1.2rem);
		color: rgba(245,240,235,0.75);
		max-width: 520px;
		line-height: 1.7;
		margin: 0 0 2.25rem;
	}
	.hero-actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	/* ─── Buttons ──────────────────────────────────────── */
	.btn {
		display: inline-flex;
		align-items: center;
		font-family: var(--font-display);
		font-weight: 600;
		font-size: 0.95rem;
		padding: 0.75em 1.75em;
		border-radius: 8px;
		text-decoration: none;
		transition: all 0.2s ease;
		cursor: pointer;
		border: 2px solid transparent;
		letter-spacing: 0.02em;
	}
	.btn-primary {
		background: var(--color-green);
		color: var(--color-cream);
		border-color: var(--color-green);
	}
	.btn-primary:hover {
		background: var(--color-green-light);
		border-color: var(--color-green-light);
		color: var(--color-cream);
		transform: translateY(-1px);
		box-shadow: 0 6px 20px rgba(45,90,39,0.35);
	}
	.btn-ghost {
		background: transparent;
		color: var(--color-cream);
		border-color: rgba(245,240,235,0.35);
	}
	.btn-ghost:hover {
		background: rgba(245,240,235,0.1);
		border-color: rgba(245,240,235,0.6);
		color: var(--color-cream);
	}
	.btn-outline {
		background: transparent;
		color: var(--color-green);
		border-color: var(--color-green);
	}
	.btn-outline:hover {
		background: var(--color-green);
		color: var(--color-cream);
		transform: translateY(-1px);
	}
	.btn-gold {
		background: var(--color-gold);
		color: var(--color-charcoal);
		border-color: var(--color-gold);
		font-weight: 700;
	}
	.btn-gold:hover {
		background: var(--color-gold-light);
		border-color: var(--color-gold-light);
		color: var(--color-charcoal);
		transform: translateY(-1px);
		box-shadow: 0 6px 20px rgba(200,151,58,0.4);
	}

	/* ─── Shared Section Layout ────────────────────────── */
	.section-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 5rem 2rem;
	}
	.section-header {
		margin-bottom: 3rem;
	}
	.section-label {
		display: inline-block;
		font-family: var(--font-display);
		font-size: 0.72rem;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--color-green);
		margin-bottom: 0.75rem;
	}
	.section-header h2 {
		margin: 0 0 0.6rem;
		color: var(--color-charcoal);
	}
	.section-header p {
		color: var(--color-muted);
		font-size: 1.05rem;
		max-width: 540px;
		margin: 0;
	}

	/* ─── Empty State ─── */
	.empty-state {
		text-align: center;
		padding: 4rem 1.5rem;
		background: var(--color-cream-dark);
		border-radius: 12px;
		color: var(--color-muted);
		font-family: var(--font-body);
		margin-bottom: 2rem;
	}

	/* ─── Categories ──────────────────────────────────── */
	.categories {
		background: var(--color-cream-dark);
	}
	.category-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.5rem;
	}
	.category-card {
		background: var(--color-cream);
		border-radius: 12px;
		padding: 2rem 1.75rem;
		border: 1px solid rgba(28,31,26,0.07);
		transition: box-shadow 0.2s, transform 0.2s;
	}
	.category-card:hover {
		box-shadow: 0 8px 32px rgba(28,31,26,0.1);
		transform: translateY(-3px);
	}
	.category-icon {
		font-size: 2.2rem;
		display: block;
		margin-bottom: 1rem;
		line-height: 1;
	}
	.category-card h3 {
		font-size: 1.15rem;
		margin-bottom: 0.6rem;
		color: var(--color-charcoal);
	}
	.category-card p {
		font-size: 0.9rem;
		color: var(--color-muted);
		line-height: 1.6;
		margin: 0;
	}

	/* ─── Post Grid ───────────────────────────────────── */
	.latest { background: var(--color-cream); }
	.post-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1.75rem;
		list-style: none;
		padding: 0;
		margin: 0 0 2.5rem;
	}
	.post-card-link {
		display: block;
		text-decoration: none;
		border-radius: 12px;
		overflow: hidden;
		background: var(--color-cream);
		border: 1px solid rgba(28,31,26,0.08);
		height: 100%;
		transition: box-shadow 0.22s, transform 0.22s;
	}
	.post-card-link:hover {
		box-shadow: 0 10px 36px rgba(28,31,26,0.12);
		transform: translateY(-4px);
	}
	.post-card-img-wrap {
		aspect-ratio: 16/9;
		overflow: hidden;
	}
	.post-card-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: transform 0.35s ease;
	}
	.post-card-link:hover .post-card-img {
		transform: scale(1.04);
	}
	.post-card-body {
		padding: 1.4rem 1.5rem 1.6rem;
	}
	.post-card-date {
		font-size: 0.75rem;
		color: var(--color-muted);
		font-family: var(--font-display);
		font-weight: 500;
		letter-spacing: 0.04em;
		margin: 0 0 0.5rem;
	}
	.post-card-title {
		font-size: 1.1rem;
		margin: 0 0 0.6rem;
		color: var(--color-charcoal);
		line-height: 1.3;
	}
	.post-card-desc {
		font-size: 0.87rem;
		color: var(--color-muted);
		margin: 0 0 1rem;
		line-height: 1.55;
	}
	.post-card-cta {
		font-family: var(--font-display);
		font-size: 0.82rem;
		font-weight: 600;
		color: var(--color-green);
		letter-spacing: 0.02em;
	}
	.all-stories-wrap {
		text-align: center;
		margin-top: 1rem;
	}

	/* ─── Newsletter ──────────────────────────────────── */
	.newsletter {
		background: linear-gradient(135deg, var(--color-green-dark) 0%, var(--color-green) 100%);
	}
	.newsletter-inner {
		text-align: center;
		padding: 5rem 2rem;
	}
	.newsletter-icon {
		font-size: 2.5rem;
		display: block;
		margin-bottom: 1rem;
	}
	.newsletter h2 {
		color: var(--color-cream);
		margin-bottom: 0.75rem;
	}
	.newsletter p {
		color: rgba(245,240,235,0.72);
		max-width: 460px;
		margin: 0 auto 2rem;
		font-size: 1.05rem;
	}

	/* ─── Responsive ──────────────────────────────────── */
	@media (max-width: 900px) {
		.category-grid { grid-template-columns: 1fr; }
		.post-grid { grid-template-columns: 1fr; }
	}
	@media (max-width: 600px) {
		.hero-inner { padding: 4rem 1.25rem; }
		.section-inner { padding: 3.5rem 1.25rem; }
		.category-grid { gap: 1rem; }
	}
</style>
