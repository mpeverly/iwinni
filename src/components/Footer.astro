---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-brand">
			<svg class="footer-icon" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<path d="M28 8 L8 40 H48 Z" stroke="currentColor" stroke-width="3" stroke-linejoin="round" fill="none"/>
				<path d="M28 8 L23 22 M28 8 L33 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
				<path d="M9 46 Q20 42 28 46 Q36 50 47 46" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
				<path d="M44 40 L39 28 L34 40 Z" fill="currentColor"/>
				<rect x="38" y="40" width="2.5" height="4" rx="1" fill="currentColor"/>
			</svg>
			<span class="footer-wordmark">IWINNI</span>
		</div>

		<p class="footer-tagline">
			The modern explorer's guide to global travel,<br />
			outdoor adventure, and high-altitude exploration.
		</p>

		<div class="footer-social">
			<a
				href="https://www.linkedin.com/company/iwinni"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Follow IWINNI on LinkedIn"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="20" height="20" fill="currentColor">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
				LinkedIn
			</a>
		</div>

		<div class="footer-links">
			<a href="/">Home</a>
			<span class="divider">·</span>
			<a href="/blog">Stories</a>
			<span class="divider">·</span>
			<a href="/about">About</a>
		</div>

		<p class="footer-copy">
			&copy; {today.getFullYear()} IWINNI. All rights reserved.
		</p>
	</div>
</footer>

<style>
	footer {
		background: var(--color-charcoal);
		color: rgba(245, 240, 235, 0.6);
		padding: 3.5em 1.5em 2.5em;
	}
	.footer-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		text-align: center;
	}
	.footer-brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		color: var(--color-cream);
	}
	.footer-icon {
		width: 32px;
		height: 32px;
		color: var(--color-gold);
	}
	.footer-wordmark {
		font-family: var(--font-display);
		font-size: 1.4rem;
		font-weight: 800;
		letter-spacing: 0.06em;
		color: var(--color-cream);
	}
	.footer-tagline {
		font-family: var(--font-body);
		font-size: 0.88rem;
		line-height: 1.6;
		color: rgba(245, 240, 235, 0.5);
		margin: 0;
		max-width: 400px;
	}
	.footer-social {
		display: flex;
		gap: 1rem;
	}
	.footer-social a {
		display: flex;
		align-items: center;
		gap: 0.45rem;
		color: rgba(245, 240, 235, 0.55);
		text-decoration: none;
		font-family: var(--font-display);
		font-size: 0.85rem;
		font-weight: 500;
		padding: 0.4em 0.9em;
		border: 1px solid rgba(245, 240, 235, 0.12);
		border-radius: 999px;
		transition: color 0.2s, border-color 0.2s, background 0.2s;
	}
	.footer-social a:hover {
		color: var(--color-gold-light);
		border-color: var(--color-gold);
		background: rgba(200, 151, 58, 0.08);
	}
	.footer-links {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-size: 0.82rem;
	}
	.footer-links a {
		color: rgba(245, 240, 235, 0.45);
		text-decoration: none;
		font-family: var(--font-display);
		font-weight: 500;
		transition: color 0.2s;
	}
	.footer-links a:hover { color: var(--color-cream); }
	.divider { color: rgba(245, 240, 235, 0.2); }
	.footer-copy {
		font-size: 0.78rem;
		color: rgba(245, 240, 235, 0.3);
		margin: 0;
		border-top: 1px solid rgba(245, 240, 235, 0.08);
		padding-top: 1.25rem;
		width: 100%;
	}
</style>
