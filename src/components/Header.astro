---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
	<nav>
		<a href="/" class="brand" aria-label="IWINNI Home">
			<svg class="brand-icon" viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<!-- Mountain -->
				<path d="M28 8 L8 40 H48 Z" stroke="currentColor" stroke-width="3" stroke-linejoin="round" fill="none"/>
				<!-- Snow cap -->
				<path d="M28 8 L23 22 M28 8 L33 22" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
				<!-- River -->
				<path d="M9 46 Q20 42 28 46 Q36 50 47 46" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" fill="none"/>
				<!-- Pine tree -->
				<path d="M44 40 L39 28 L34 40 Z" fill="currentColor"/>
				<rect x="38" y="40" width="2.5" height="4" rx="1" fill="currentColor"/>
			</svg>
			<span class="brand-name">{SITE_TITLE}</span>
		</a>

		<div class="nav-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Stories</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>

		<div class="social-links">
			<a
				href="https://www.linkedin.com/company/iwinni"
				target="_blank"
				rel="noopener noreferrer"
				aria-label="Follow IWINNI on LinkedIn"
				title="LinkedIn"
			>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22" fill="currentColor">
					<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
				</svg>
			</a>
		</div>

		<button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="Toggle menu" aria-expanded="false">
			<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
				<line x1="3" y1="6" x2="21" y2="6"/>
				<line x1="3" y1="12" x2="21" y2="12"/>
				<line x1="3" y1="18" x2="21" y2="18"/>
			</svg>
		</button>
	</nav>

	<!-- Mobile drawer -->
	<div class="mobile-nav" id="mobile-nav" aria-hidden="true">
		<HeaderLink href="/">Home</HeaderLink>
		<HeaderLink href="/blog">Stories</HeaderLink>
		<HeaderLink href="/about">About</HeaderLink>
		<a
			href="https://www.linkedin.com/company/iwinni"
			target="_blank"
			rel="noopener noreferrer"
			class="mobile-social"
		>LinkedIn ↗</a>
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const nav = document.getElementById('mobile-nav');
	btn?.addEventListener('click', () => {
		const open = nav?.classList.toggle('open');
		btn.setAttribute('aria-expanded', String(open));
		nav?.setAttribute('aria-hidden', String(!open));
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-green);
		box-shadow: 0 1px 0 rgba(0,0,0,0.15), 0 4px 16px rgba(0,0,0,0.12);
	}

	nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 1.5em;
		height: 64px;
	}

	/* Brand */
	.brand {
		display: flex;
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		color: var(--color-cream);
		flex-shrink: 0;
		margin-right: auto;
	}
	.brand:hover { color: var(--color-gold-light); }
	.brand-icon {
		width: 34px;
		height: 34px;
		color: var(--color-cream);
		flex-shrink: 0;
		transition: color 0.2s;
	}
	.brand:hover .brand-icon { color: var(--color-gold-light); }
	.brand-name {
		font-family: var(--font-display);
		font-size: 1.3rem;
		font-weight: 800;
		letter-spacing: 0.04em;
		line-height: 1;
	}

	/* Desktop nav links */
	.nav-links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
	}

	/* Social */
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-left: 0.5rem;
	}
	.social-links a {
		display: flex;
		align-items: center;
		color: rgba(245, 240, 235, 0.7);
		transition: color 0.2s;
		padding: 0.35em;
		border-radius: 6px;
	}
	.social-links a:hover {
		color: var(--color-gold-light);
		background: rgba(255,255,255,0.08);
	}

	/* Mobile button */
	.mobile-menu-btn {
		display: none;
		background: none;
		border: none;
		color: var(--color-cream);
		cursor: pointer;
		padding: 0.4em;
		border-radius: 6px;
		transition: background 0.2s;
	}
	.mobile-menu-btn:hover { background: rgba(255,255,255,0.1); }

	/* Mobile drawer */
	.mobile-nav {
		display: none;
		flex-direction: column;
		background: var(--color-green-dark);
		padding: 0.75em 1.5em 1.25em;
		gap: 0.25rem;
		border-top: 1px solid rgba(255,255,255,0.1);
	}
	.mobile-nav.open { display: flex; }
	.mobile-social {
		color: rgba(245,240,235,0.6);
		text-decoration: none;
		font-family: var(--font-display);
		font-size: 0.9rem;
		padding: 0.5em 0;
		font-weight: 500;
		transition: color 0.2s;
	}
	.mobile-social:hover { color: var(--color-gold-light); }

	@media (max-width: 720px) {
		.nav-links, .social-links { display: none; }
		.mobile-menu-btn { display: flex; }
	}
</style>
